{
  "expo": {
    "name": "ChatSpend",
    "slug": "chatspend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#4F46E5"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chatspend.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "需要访问相机以拍摄小票进行记账",
        "NSMicrophoneUsageDescription": "需要访问麦克风以进行语音记账"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4F46E5"
      },
      "package": "com.chatspend.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "WRITE_EXTERNAL_STORAGE",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "允许ChatSpend访问相机以拍摄小票"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "允许ChatSpend访问麦克风以进行语音记账"
        }
      ],
      "expo-notifications"
    ],
    "extra": {
      "apiUrl": "http://localhost:8000/api/v1"
    }
  }
}
